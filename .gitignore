# ==============================
# PlatformIO 编译缓存（必忽略）
# ==============================
.pio/
.pioenvs/
.piolibdeps/
managed_components/
build/
dist/
build.log        # 你的日志文件

# ==============================
# 第三方组件库（你的核心冗余目录）
# ==============================
components/
lib/

# ==============================
# ESP-IDF 自动生成文件
# ==============================
sdkconfig.old
sdkconfig.*
dependencies.lock # ESP-IDF 依赖锁文件

# ==============================
# VS Code 编辑器配置
# ==============================
.vscode/
*.code-workspace

# ==============================
# 系统临时文件
# ==============================
.DS_Store
Thumbs.db
*.tmp
*.bak
*.swp

# ==============================
# 个人无用文件夹
# ==============================
Camera/
Download/
Movies/
Music/
Pictures/
Screenshots/
test/

# ==============================
# 自定义无用文件
# ==============================
config.h
include/README
lib/README